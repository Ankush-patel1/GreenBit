# GreenBit Root Environment Configuration
# Copy this file to .env in the root folder for frontend config.
# Never commit .env files to version control.

# ─── Backend API ──────────────────────────────────────────────────────────────
# Frontend API Base URL pointing to the running backend service
VITE_API_BASE_URL="http://localhost:8000"

# ─── Firebase Authentication ──────────────────────────────────────────────────
# All Firebase credentials must be set here. Find these values in:
# Firebase Console → Project Settings → Your apps → SDK setup and configuration
VITE_FIREBASE_API_KEY="your-firebase-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"
VITE_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"
