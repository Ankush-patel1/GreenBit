# GreenBit Backend Environment Configuration Example
# Copy this file to .env and fill in the values before running.

# Supabase PostgreSQL Connection URL
DATABASE_URL="postgresql://postgres.your-project-id:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase Direct Connection URL
DIRECT_URL="postgresql://postgres.your-project-id:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# JWT Token Signing Secret Key (Keep this secret and high entropy!)
SECRET_KEY="your-32-byte-hexadecimal-secret-key-goes-here"

# Gemini LLM API Key for AI Sustainability Coach and RAG Library Assistant
GEMINI_API_KEY="AIzaSyYourGeminiApiKeyGoesHere"

# Allowed CORS origins (comma-separated, no wildcards in production)
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"
